  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:watch": "npx nodemon --watch src -e ts,tsx,html,css --exec 'npm run build'",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "lint": "eslint .",
    "preview": "wxt preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "xvfb-run -a playwright test",
    "test:e2e:headed": "xvfb-run -a playwright test --headed",
    "test:serenity": "xvfb-run -a playwright test e2e/serenity/specs",
    "test:smoke": "xvfb-run -a playwright test e2e/serenity/specs/smoke.spec.ts",
    "test:e2e:setup": "playwright install chromium",
    "typecheck": "tsc -b"
  },
